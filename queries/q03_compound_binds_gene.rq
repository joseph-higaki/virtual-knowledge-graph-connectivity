# rung 4 — Ontop -> Trino -> (Postgres + Iceberg). Compounds that bind gene AGTR1. Forces a
# cross-catalog join: the compound node + binding edge live in iceberg.hetionet (MinIO), the anchor
# gene in postgresql.public — Trino federates them. Anchored + projected by LABEL only (parity on
# labels, never IRIs — CLAUDE.md #7).
PREFIX hetio: <https://het.io/schema/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?compoundLabel WHERE {
  ?gene a hetio:Gene ;
        rdfs:label "AGTR1" .
  ?compound a hetio:Compound ;
            rdfs:label ?compoundLabel ;
            hetio:binds ?gene .
}
ORDER BY ?compoundLabel
