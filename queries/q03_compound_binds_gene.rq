# Compounds that bind gene AGTR1, anchored + projected by LABEL
# Spans two relational sources (
# a cross-store join): the compound node + binding edge
PREFIX hetio: <https://het.io/schema/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?compoundLabel WHERE {
  ?gene a hetio:Gene ;
        rdfs:label "AGTR1" .
  ?compound a hetio:Compound ;
            rdfs:label ?compoundLabel ;
            hetio:binds ?gene .
}
ORDER BY ?compoundLabel
