# Compounds that bind gene AGTR1, anchored + projected by LABEL only — parity on labels, never IRIs
# (CLAUDE.md #7). Spans two relational sources (a cross-store join): the compound node + binding edge
# on one, the anchor gene on the other — federated underneath.
PREFIX hetio: <https://het.io/schema/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?compoundLabel WHERE {
  ?gene a hetio:Gene ;
        rdfs:label "AGTR1" .
  ?compound a hetio:Compound ;
            rdfs:label ?compoundLabel ;
            hetio:binds ?gene .
}
ORDER BY ?compoundLabel
