# Two-hop: diseases treated by compounds that bind gene AGTR1 (gene <-binds- compound -treats-> disease).
# Projected by LABEL only — parity on labels, never IRIs (CLAUDE.md #7); no DISTINCT, both endpoints
# return the same multiset. Spans two relational sources and crosses between them twice — the anchor
# gene and result diseases on one, the compound + both edges on the other.
PREFIX hetio: <https://het.io/schema/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?diseaseLabel WHERE {
  ?gene a hetio:Gene ;
        rdfs:label "AGTR1" .
  ?compound hetio:binds ?gene ;
            hetio:treats ?disease .
  ?disease a hetio:Disease ;
           rdfs:label ?diseaseLabel .
}
ORDER BY ?diseaseLabel
