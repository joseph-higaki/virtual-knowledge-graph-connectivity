# The gene association disease join resolve
# within a single relational source.
PREFIX hetio: <https://het.io/schema/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?geneLabel WHERE {
  ?disease a hetio:Disease ;
           rdfs:label "restless legs syndrome" ;
           hetio:associates ?gene .
  ?gene a hetio:Gene ;
        rdfs:label ?geneLabel .
}
ORDER BY ?geneLabel
