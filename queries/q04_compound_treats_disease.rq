# rung 4 — Ontop -> Trino -> (Postgres + Iceberg). Compounds that treat Alzheimer's disease. Forces
# a cross-catalog join: the compound node + treatment edge live in iceberg.hetionet (MinIO), the
# anchor disease in postgresql.public — Trino federates them. Projected by LABEL only (CLAUDE.md #7).
PREFIX hetio: <https://het.io/schema/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?compoundLabel WHERE {
  ?disease a hetio:Disease ;
           rdfs:label "Alzheimer's disease" .
  ?compound a hetio:Compound ;
            rdfs:label ?compoundLabel ;
            hetio:treats ?disease .
}
ORDER BY ?compoundLabel
