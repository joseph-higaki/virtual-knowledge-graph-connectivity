# Every compound, projected by LABEL only — parity is compared on labels, never IRIs (Ontop and the
# ground truth mint different IRI schemes; CLAUDE.md #7). Resolves against a single relational source.
# ORDER BY lines the side-by-side diff up (parity itself is modulo order).
PREFIX hetio: <https://het.io/schema/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?compoundLabel WHERE {
  ?compound a hetio:Compound ;
            rdfs:label ?compoundLabel .
}
ORDER BY ?compoundLabel
