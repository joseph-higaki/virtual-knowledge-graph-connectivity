# COUNT over the compound node table. Projects only the scalar ?n; parity compares the count value:
# Ontop's compound count must equal the hetio:Compound instance count in the ground truth. Single
# relational source; the engine delegates the COUNT down to the scan.
PREFIX hetio: <https://het.io/schema/>

SELECT (COUNT(?compound) AS ?n) WHERE {
  ?compound a hetio:Compound .
}
