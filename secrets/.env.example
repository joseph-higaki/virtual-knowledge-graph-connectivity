# Template for secrets/.env — copy to secrets/.env and adjust. secrets/.env is gitignored.
# Local-first: values here are docker-compose dev defaults, safe to commit as a template.
# Required vars fail loud if unset/empty (never silently defaulted): the harness raises on the
# SPARQL URLs via require_env, and `compose up` aborts on the Postgres creds via ${VAR:?...}.
#
# Two audiences for hostnames: containers reach each other by compose SERVICE NAME
# (postgres/trino/minio); host-side Python tools (harness) reach them via localhost + mapped port.

# --- Ground truth: existing GraphDB (base UI/REST on :7200) ---
# The SPARQL endpoint is per-repository; confirm GRAPHDB_REPOSITORY matches your Project-1 repo.
GRAPHDB_BASE_URL=http://localhost:7200
GRAPHDB_REPOSITORY=hetionet
GROUND_TRUTH_SPARQL_URL=http://localhost:7200/repositories/hetionet

# --- System under test: standalone Ontop SPARQL endpoint (host-side; 7300 avoids 8080) ---
ONTOP_HOST_PORT=7300
ONTOP_SPARQL_URL=http://localhost:7300/sparql

# --- PostgreSQL (rung 2 direct; rung 4 via Trino postgresql catalog) ---
POSTGRES_DB=hetionet
POSTGRES_USER=hetionet
POSTGRES_PASSWORD=change-me
POSTGRES_HOST_PORT=5432
# JDBC URL Ontop uses inside the compose network (service hostname, not localhost).
ONTOP_PG_JDBC_URL=jdbc:postgresql://postgres:5432/hetionet

# --- Trino (rungs 3 & 4): container :8080 mapped to host :8081 ---
TRINO_HOST_PORT=8081
ONTOP_TRINO_JDBC_URL=jdbc:trino://trino:8080/iceberg/hetionet

# --- Nessie (Iceberg catalog, rungs 3 & 4): container :19120 mapped to host for debugging ---
NESSIE_HOST_PORT=19120

# --- MinIO / S3 backing Iceberg (dev creds only) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_HOST_S3_PORT=9000
MINIO_HOST_CONSOLE_PORT=9001
S3_ENDPOINT=http://minio:9000
S3_BUCKET=warehouse
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=change-me
AWS_REGION=us-east-1
