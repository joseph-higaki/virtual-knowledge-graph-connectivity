# --- Secrets / env ---
# Real env lives in secrets/.env (dev creds, oracle/JDBC coords); only the template is tracked.
secrets/.env
secrets/*.local
.env
*.env
!secrets/.env.example
!*.env.example

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Fetched / generated data ---
# hetionet TSVs and derived RDF land here; the ~469 MB hetionet.ttl must never enter history.
# Exception: the 45 KB smoke ttl is a tracked reference oracle. Glob-then-negate is required
# because a plain `data/hetionet/` dir exclude blocks re-including any file beneath it.
data/hetionet/**
!data/hetionet/rdf/
!data/hetionet/rdf/hetionet-smoke.ttl

# --- Local docker volume mounts (if bind-mounted rather than named volumes) ---
.volumes/
minio-data/
pgdata/
trino-data/

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
*.swp
