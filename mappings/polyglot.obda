[PrefixDeclaration]
hetio:		https://het.io/schema/
rdfs:		http://www.w3.org/2000/01/rdf-schema#
xsd:		http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	gene
target		<https://het.io/gene/{id}> a hetio:Gene ; rdfs:label {name}^^xsd:string .
source		SELECT id, name FROM postgresql.public.gene

mappingId	disease
target		<https://het.io/disease/{id}> a hetio:Disease ; rdfs:label {name}^^xsd:string .
source		SELECT id, name FROM postgresql.public.disease

mappingId	disease_associates_gene
target		<https://het.io/disease/{disease_id}> hetio:associates <https://het.io/gene/{gene_id}> .
source		SELECT disease_id, gene_id FROM postgresql.public.gene_disease_association

mappingId	compound
target		<https://het.io/compound/{id}> a hetio:Compound ; rdfs:label {name}^^xsd:string .
source		SELECT id, name FROM iceberg.hetionet.compound

mappingId	compound_binds_gene
target		<https://het.io/compound/{compound_id}> hetio:binds <https://het.io/gene/{gene_id}> .
source		SELECT compound_id, gene_id FROM iceberg.hetionet.compound_gene_binding

mappingId	compound_treats_disease
target		<https://het.io/compound/{compound_id}> hetio:treats <https://het.io/disease/{disease_id}> .
source		SELECT compound_id, disease_id FROM iceberg.hetionet.compound_disease_treatment
]]
